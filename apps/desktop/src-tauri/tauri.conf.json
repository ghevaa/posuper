{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pos-yoga",
  "version": "0.1.2",
  "identifier": "com.ghevary.posyoga",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -w apps/web",
    "beforeBuildCommand": "cd ../.. && npm run build -w apps/web"
  },
  "app": {
    "windows": [
      {
        "title": "POS Yoga",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ghevaa/posuper/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5MjcwMUUzMTUxQ0YzNTIKUldSUzh4d1Y0d0VueVM4TlZ6SXRBRkk4akgyTTgwYldqWElJdVF3S2xzdUR6MGFkVjk0ZitHTjEK"
    }
  }
}
